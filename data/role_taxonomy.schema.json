{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://career-alignment.local/schemas/role_taxonomy.schema.json",
  "title": "Role taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "created", "description", "roles"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "created": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "description": {"type": "string", "minLength": 1},
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/role"}
    }
  },
  "$defs": {
    "motivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "impact_orientation",
        "capital_allocation",
        "innovation",
        "leadership_scale",
        "autonomy",
        "stability_vs_volatility",
        "prestige_sensitivity"
      ],
      "properties": {
        "impact_orientation": {"$ref": "#/$defs/motivationLevel"},
        "capital_allocation": {"$ref": "#/$defs/motivationLevel"},
        "innovation": {"$ref": "#/$defs/motivationLevel"},
        "leadership_scale": {"$ref": "#/$defs/motivationLevel"},
        "autonomy": {"$ref": "#/$defs/motivationLevel"},
        "stability_vs_volatility": {"$ref": "#/$defs/motivationLevel"},
        "prestige_sensitivity": {"$ref": "#/$defs/motivationLevel"}
      }
    },
    "motivationLevel": {
      "type": "string",
      "enum": ["low", "moderate", "high"]
    },
    "blsData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bls_top_skills", "bls_median_wage_2024", "bls_typical_education", "bls_employment_growth_pct_2024_34"],
      "properties": {
        "bls_top_skills": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "bls_median_wage_2024": {"type": "number"},
        "bls_typical_education": {"type": "string", "minLength": 1},
        "bls_employment_growth_pct_2024_34": {"type": "number"}
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_id",
        "role_name",
        "onet_code",
        "category",
        "description",
        "required_skills",
        "preferred_skills",
        "barrier_conditions",
        "expected_signals",
        "motivation_attributes",
        "bls_data"
      ],
      "properties": {
        "role_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "role_name": {"type": "string", "minLength": 1},
        "onet_code": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "required_skills": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "preferred_skills": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "barrier_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "expected_signals": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "motivation_attributes": {"$ref": "#/$defs/motivation"},
        "bls_data": {"$ref": "#/$defs/blsData"},
        "functional_category": {"type": "string"},
        "track": {"type": "string"},
        "mba_track": {"type": "boolean"},
        "babson_fit": {"type": "boolean"}
      }
    }
  }
}
